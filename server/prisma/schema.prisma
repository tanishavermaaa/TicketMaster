datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String      @id @default(uuid())
  email           String      @unique
  password        String
  name            String
  role            String      // "CUSTOMER" or "AGENT"
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  ticketsCreated  Ticket[]    @relation("CreatedTickets")
  ticketsAssigned Ticket[]    @relation("AssignedTickets")
  comments        Comment[]
  auditLogs       AuditLog[]
}

model Ticket {
  id                String      @id @default(uuid())
  title             String
  description       String
  status            String      @default("OPEN")        // "OPEN", "IN_PROGRESS", "RESOLVED", "CLOSED"
  priority          String      @default("LOW")         // "LOW", "MEDIUM", "HIGH", "CRITICAL"
  category          String      @default("GENERAL")     // "BILLING", "TECHNICAL_ISSUE", "ACCOUNT_ACCESS", "FEATURE_REQUEST", "GENERAL_INQUIRY"
  createdById       String
  createdBy         User        @relation("CreatedTickets", fields: [createdById], references: [id], onDelete: Cascade)
  assignedToId      String?
  assignedTo        User?       @relation("AssignedTickets", fields: [assignedToId], references: [id], onDelete: SetNull)
  suggestedResponse String?     // AI response suggestion
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  comments          Comment[]
  auditLogs         AuditLog[]
}

model Comment {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // "STATUS_CHANGE", "ASSIGNMENT", "TICKET_CREATED", "COMMENT_ADDED"
  details   String   // JSON string with extra details (e.g. old and new status values)
  createdAt DateTime @default(now())
}
